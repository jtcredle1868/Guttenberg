# Guttenberg Environment Configuration
# Copy to .env and fill in your values

# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=guttenberg.settings.development

# Database (PostgreSQL)
DB_NAME=guttenberg
DB_USER=guttenberg
DB_PASSWORD=guttenberg
DB_HOST=localhost
DB_PORT=5432

# Redis (Celery broker)
CELERY_BROKER_URL=redis://localhost:6379/0

# Claude AI (Anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Master Prose Platform Integration
MPP_REFINERY_API_URL=https://api.refinery.masterprose.io/v1
MPP_FORGE_API_URL=https://api.forge.masterprose.io/v1
MPP_SCRYBE_API_URL=https://api.scrybe.masterprose.io/v1
MPP_IDENTITY_URL=https://identity.masterprose.io/v1

# AWS S3 (File Storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=guttenberg-manuscripts
AWS_S3_REGION_NAME=us-east-1

# Stripe (Payments)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
REACT_APP_API_URL=http://localhost:8000/api/v1
